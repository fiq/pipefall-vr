<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature
        android:glEsVersion="0x00030002"
        android:required="true" />

    <uses-feature
        android:name="android.hardware.vr.headtracking"
        android:required="true"
        android:version="1" />

    <application
        android:allowBackup="false"
        android:hasCode="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:installLocation="auto"
        android:resizeableActivity="false"
        android:theme="@style/Theme.Pressure">

        <meta-data
            android:name="com.oculus.supportedDevices"
            android:value="quest2|quest3|quest3s" />

        <activity
            android:name=".QuestActivity"
            android:excludeFromRecents="true"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:exported="true"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
                <!-- com.oculus.intent.category.VR is intentionally omitted until the app
                     creates an OpenXR session. With it present, Horizon OS launches the
                     activity in immersive VR mode and shows a loading screen while waiting
                     for the app to take over VR rendering, which never happens without
                     OpenXR integration. Without it, the app runs as a 2D panel. -->
            </intent-filter>
        </activity>
    </application>

</manifest>
